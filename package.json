{
  "name": "payload-email-ses",
  "version": "1.0.1",
  "description": "AWS SESv2 email adapter for Payload CMS 3.x",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@aws-sdk/client-sesv2": "^3.700.0",
    "payload": "^3.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-sesv2": "^3.700.0",
    "payload": "^3.82.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "prettier": "^3.0.0"
  },
  "keywords": [
    "payload",
    "payload-cms",
    "email",
    "ses",
    "aws-ses",
    "sesv2",
    "adapter",
    "payload-email"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kodes-agency/payload-email-ses"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.14.0"
}
